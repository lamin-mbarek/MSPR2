# Copier en .env puis adapter si besoin :  cp .env.example .env

# ─── Simulateur IoT ───────────────────────────────────────────────────────────
# normal = valeurs dans les seuils ; anomalies = génère des dépassements (alertes)
SIM_MODE=normal
SIM_INTERVAL=10

# ─── Origine publique du front (doit correspondre au port mappé sur nginx) ────
FRONTEND_ORIGIN=http://localhost:8082

# ─── Email (laisser vide = mode démo console) ─────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alertes@futurekawa.com
SMTP_USE_TLS=true

# Destinataire des alertes Node-RED (si vide => SMTP_FROM). Node-RED logue en
# console si SMTP_HOST est vide.
SMTP_TO=
